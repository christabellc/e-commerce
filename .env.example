# ---- HTTP ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=*

# ---- Postgres ----
# Either set DATABASE_URL, or the individual PG* values below.
DATABASE_URL=postgres://buckets:buckets@localhost:5432/buckets
PGHOST=localhost
PGPORT=5432
PGUSER=buckets
PGPASSWORD=buckets
PGDATABASE=buckets

# ---- Redis (caching + rate limiting). Optional: app degrades gracefully if absent ----
REDIS_URL=redis://localhost:6379

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Tunables ----
PRODUCTS_CACHE_TTL_SECONDS=60
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
RATE_LIMIT_ORDER_MAX=10
RATE_LIMIT_ORDER_WINDOW_SECONDS=60
